# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.supabase.co:5432/trafficbook

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Redis
REDIS_URL=redis://redis:6379

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=traffic-service
KEYCLOAK_CLIENT_ID=traffic-app

# Region configuration
REGION=EU
REGION_US_URL=https://us.trafficbook.example.com
REGION_APAC_URL=https://apac.trafficbook.example.com

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# App
APP_NAME=trafficbook
DEBUG=false
