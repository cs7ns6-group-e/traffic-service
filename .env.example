# Region (change per VM: EU / US / APAC)
REGION=EU
REGION_US_URL=http://10.0.2.11
REGION_APAC_URL=http://10.0.3.11

# JWT (IDENTICAL on all 3 VMs)
JWT_SECRET=your_secret_from_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# PostgreSQL
POSTGRES_USER=trafficbook
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=trafficbook
DATABASE_URL=postgresql://trafficbook:your_strong_password@postgres:5432/trafficbook

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_ERLANG_COOKIE=trafficbook-cluster-cookie

# Redis
REDIS_URL=redis://redis:6379

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Monitoring
GRAFANA_ADMIN_PASSWORD=admin123
